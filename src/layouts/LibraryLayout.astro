---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import PwaInstallBanner from "../components/PwaInstallBanner.astro";

interface Props {
  title: string;
  description: string;
  /** /images/ 以下の相対パス（例: "shadow-library/entrance-hall.webp"）。 */
  bgImage: string;
  /** 全画面背景の焦点位置。CSS object-position 形式。 */
  bgPosition?: string;
  /** モバイル幅だけの全画面背景焦点位置。 */
  bgPositionMobile?: string;
}

const { title, description, bgImage, bgPosition = "center", bgPositionMobile } = Astro.props;

const SITE = Astro.site ?? new URL("https://theo-hayami.llll-ll.com");
const canonical = new URL(Astro.url.pathname, SITE).href;

// OGP/Twitter Card の画像＝耽美キービジュアル（本作の売り）。sync-assets.mjs が
// assets/images/ を public/images/ へ複製するので配信URLは /images/...。
// og:image は絶対URLが必須なので Astro.site を基準に絶対化する。
const ogImage = new URL("/images/promotional/cast/shadow-library-cast.webp", SITE).href;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Issue #59: astro.config.mjs の manifest.theme_color/background_color と同じ #0a0910
         （--color-th-ink-deep）に揃える。ここが manifest と別値だと、起動スプラッシュ→本描画の
         切り替わりで色が変わって継ぎ目が出る（hanoba #478 と同種の色ズレ）ため統一する。 -->
    <meta name="theme-color" content="#0a0910" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hina+Mincho&display=swap" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- manifest は public/manifest.webmanifest の静的ファイル。明示しないとブラウザが
         manifest を発見できずインストール可能と認識されない（実機で確認済み）。 -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="せおはやみ" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <div
      class="th-backdrop"
      aria-hidden="true"
      style={`--th-backdrop-position: ${bgPosition}; ${bgPositionMobile ? `--th-backdrop-position-mobile: ${bgPositionMobile};` : ""}`}
    >
      <img class="th-backdrop__base" src={`/images/${bgImage}`} alt="" loading="eager" />
      {/* #20: ゲーム用素材の引き伸ばしで出るアップスケールの粗さを、同じ絵のぼかしコピーを
          overlay 合成で軽く重ねて目立たなくする（name-name #316 の「平坦領域に階調＝高見え」を
          CSS で薄く適用）。ぼかしが粗さをマスクし、overlay が平坦領域に階調を足す。 */}
      {/* 親 .th-backdrop が既に aria-hidden なので、この img には付けない（冗長回避）。 */}
      <img class="th-backdrop__glow" src={`/images/${bgImage}`} alt="" loading="eager" />
    </div>
    <div class="relative z-10 min-h-screen flex flex-col">
      <main class="flex-1 w-full">
        <slot />
      </main>
      <SiteFooter />
    </div>
    <PwaInstallBanner />

    <script>
      // #34: スクロール量に応じて全画面背景（.th-backdrop）を滑らかに拡大し「奥へ進む」印象を出す。
      // 併せて、モバイルのツールバー collapse による visual viewport 高さ変化で起きる被覆の
      // 再計算（下端スクロールでガクッと拡大再描画される）を、同じ --th-zoom 更新経路で JS が
      // 明示制御して吸収する。ReadMarks.astro と同じ作法（通常の module <script>・client 島なし）。

      // 演出の上限 cap（+12%）。後でチューニングしやすいよう先頭に定数で置く。
      const MAX_EXTRA = 0.12;

      const backdrop = document.querySelector<HTMLElement>(".th-backdrop");
      // reduced-motion を尊重する読者にはズームを掛けない（--th-zoom は CSS 既定の 1 のまま・リスナーも張らない）。
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (backdrop && !prefersReducedMotion) {
        // クロージャ内での非null narrowing を確定させるためローカルに束ねる。
        const el = backdrop;
        let targetZoom = 1;
        let currentZoom = 1;
        let frame = 0;

        function calculateZoom() {
          // 進捗 p = scrollY / 残りスクロール可能量 を 0..1 にクランプ。
          const max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const p = Math.min(1, Math.max(0, window.scrollY / max));
          return 1 + p * MAX_EXTRA; // 1.0 .. 1.12（上限 cap）
        }

        function animateZoom() {
          const delta = targetZoom - currentZoom;
          if (Math.abs(delta) < 0.0004) {
            currentZoom = targetZoom;
            el.style.setProperty("--th-zoom", currentZoom.toFixed(4));
            frame = 0;
            return;
          }

          // 急スクロール時も一気に飛ばさず、少し遅れて追従させる。
          currentZoom += delta * 0.14;
          el.style.setProperty("--th-zoom", currentZoom.toFixed(4));
          frame = requestAnimationFrame(animateZoom);
        }

        // scroll では目標値だけ更新し、描画値は rAF の lerp で滑らかに追従させる。
        function requestZoom() {
          targetZoom = calculateZoom();
          if (!frame) frame = requestAnimationFrame(animateZoom);
        }

        window.addEventListener("scroll", requestZoom, { passive: true });

        // ツールバー collapse で visual viewport が変化するタイミングでも --th-zoom を再適用し、
        // ブラウザ都合のガクツキを JS の明示制御で吸収する。非対応環境（visualViewport なし）では
        // 通常の scroll だけで動くフォールバック。
        if (window.visualViewport) {
          window.visualViewport.addEventListener("resize", requestZoom, { passive: true });
          window.visualViewport.addEventListener("scroll", requestZoom, { passive: true });
        }

        // 初期化: 現在のスクロール位置基準で1回反映（途中位置への復元リロードにも対応）。
        currentZoom = calculateZoom();
        targetZoom = currentZoom;
        el.style.setProperty("--th-zoom", currentZoom.toFixed(4));
      }
    </script>

    <script>
      // #59: PWA更新検知〜自動reload。mypace（repos/2025/mypace/apps/web/src/main.tsx）と同じ流れ:
      // onNeedRefresh で overlay を出し、sessionStorage に記録し（reload loop 防止のcooldown用）、
      // controllerchange リスナーを張ってから SKIP_WAITING を送り、新SWが制御を
      // 握った時点でreloadする。controllerchange が来ない環境向けにfallback reloadも用意する。
      // cooldown 判定・reload多重発火防止ガード（#68）はいずれも純粋関数として ../lib/pwa-update.ts
      // に切り出してvitestでテストする（dev-doctrine: 索引・判定ロジックは純粋関数に切り出し、
      // .astro は組み立てだけにする）。
      import {
        PWA_UPDATE_COOLDOWN_MS,
        createReloadOnce,
        getLastUpdateAt,
        recordUpdateAt,
        shouldSkipUpdate,
      } from "../lib/pwa-update";

      // controllerchange が来ない場合に備えたfallback reloadまでの待ち時間。
      const FALLBACK_RELOAD_MS = 2000;

      if ("serviceWorker" in navigator) {
        registerServiceWorker().catch(() => {});
      }

      async function registerServiceWorker() {
        const registration = await navigator.serviceWorker.register("/sw.js");
        // 起動時に一度だけ更新チェックする。オフライン等の失敗は無視（次回起動時に再試行される）。
        registration.update().catch(() => {});

        if (registration.waiting && navigator.serviceWorker.controller) {
          refreshWith(registration.waiting);
        }

        registration.addEventListener("updatefound", () => {
          const worker = registration.installing;
          if (!worker) return;
          worker.addEventListener("statechange", () => {
            if (worker.state === "installed" && navigator.serviceWorker.controller) {
              refreshWith(worker);
            }
          });
        });
      }

      function refreshWith(worker: ServiceWorker) {
        if (shouldSkipUpdate(getLastUpdateAt(), Date.now(), PWA_UPDATE_COOLDOWN_MS)) {
          // 直近に更新済み（cooldown中）。reload loop 防止のため今回は何もしない。
          return;
        }
        recordUpdateAt(Date.now());

        const overlay = document.createElement("div");
        overlay.className = "th-pwa-overlay";
        overlay.setAttribute("role", "status");
        overlay.setAttribute("aria-live", "polite");
        const panel = document.createElement("div");
        panel.className = "th-pwa-overlay__panel th-panel";
        panel.textContent = "新しい版があります。再起動します…";
        overlay.appendChild(panel);
        document.body.appendChild(overlay);

        // controllerchange・postMessage失敗・fallback timeoutの3経路から呼ばれうるが、
        // 実際にreloadするのは一度だけにする（#68、ガード判定は ../lib/pwa-update.ts でテスト）。
        const reloadOnce = createReloadOnce(() => window.location.reload());

        // SKIP_WAITING が発火させる controllerchange を待ってから reload する
        // （呼び出す前にリスナーを張っておく）。
        navigator.serviceWorker.addEventListener("controllerchange", reloadOnce, { once: true });

        try {
          worker.postMessage({ type: "SKIP_WAITING" });
        } catch {
          reloadOnce();
        }

        // controllerchange が来ない環境向けのfallback。
        setTimeout(() => {
          reloadOnce();
        }, FALLBACK_RELOAD_MS);
      }
    </script>
  </body>
</html>

---
import type { ResidentMeta } from "../data/residents";

interface Props {
  resident: ResidentMeta;
  /** その住人が答えている業の数（バッジ表示用）。 */
  themeCount: number;
  /** この住人の全読むページ slug（`業__住人`）。既読数バッジ用（Issue #30・クライアントで集計）。 */
  readGroup: string[];
}
const { resident, themeCount, readGroup } = Astro.props;
---

{/*
  display:contents のラッパで <a>（扉）を .th-grid の直接の grid item のまま保ち、
  参戦ムービースロットを <a> の外側＝兄弟に置く。将来ここへ置くトリガー
  （<a>/<button>）は <a> の入れ子にできない（不正HTML・非機能）ため。
*/}
<div class="contents">
  <a
    href={`/residents/${resident.slug}`}
    class="th-resident-card group block no-underline"
    data-read-group={readGroup.join(",")}
  >
    <div class="th-resident-card__art">
      <img
        src={`/images/promotional/residents/${resident.slug}-feature.webp`}
        alt=""
        loading="lazy"
        width="1672"
        height="941"
      />
    </div>
    <div class="th-resident-card__body">
      {/* 顔アップカードは LoRA 学習用のバストアップ絵（assets/images/<char>/bust.webp）を使う
          （全身立ち絵の兼用ではない・Issue #20「顔アップカード＝LoRA 元の顔アップ」）。 */}
      <div class="th-resident-card__portrait th-face-crop th-face-crop--bust">
        <img src={`/images/${resident.slug}/bust.webp`} alt="" loading="lazy" />
      </div>
      <p class="th-resident-card__kicker">Resident File</p>
      <p class="th-resident-card__name">{resident.name}</p>
      <p class="th-resident-card__meta">能力：{resident.ability}（{resident.thought}）</p>
      <p class="th-resident-card__count">{themeCount}の業に答える</p>
      {/* 既読数の蔵書票（Issue #30）。既読0なら hidden のまま。クライアントで ReadMarks が埋める。 */}
      <p class="th-read-badge text-xs mt-2" data-read-count hidden></p>
    </div>
  </a>
  {/* 将来: 参戦ムービー導線のスロット（studio-yokonami・Issue #21で後回し）。<a> の外側＝兄弟に置く。 */}
  <div data-slot="entrance-movie" hidden></div>
</div>

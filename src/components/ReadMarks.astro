---
// 索引の既読反映（Issue #30・クライアント専用）。描画後に localStorage の既読集合を読み、
// - 個別セル（`data-slug="業__住人"`）で既読のものに `.is-read` を付ける（暗くせず、金の灯り＋金の「読了」蔵書印＝達成の印）。
// - 集計カード（`data-read-group="slug,slug,..."`）で既読数を数え、`[data-read-count]` に「N/M 完読」を出し、
//   同じカード内の `.th-read-gauge__fill` の幅も進捗率で更新する（Issue #73）。
//   全部読み終えたカードには `.is-read-all` を付ける。
// localStorage はクライアント専用なので必ず描画後（module script は defer で DOM 構築後に走る）に実行する。
//
// import で readStore.ts を使い、キー/形式の二重定義を避ける（唯一の正本＝readStore.ts）。
// このコンポーネントは索引ページに1つ置けばよい（Astro が module script を1回だけ束ねる）。
//
// 個別セルの読了印（.th-read-stamp）は「読了」のまま変更しない。集計カードの分数バッジだけ
// 「完読」に改称する（同じ語を両方で使うと全読了状態の意味が重複して紛らわしいため・Issue #73）。
---

<script>
  import { getReadSet, readRatioPercent } from "../lib/readStore";

  function applyReadMarks() {
    const readSet = getReadSet();

    // 個別セル: 既読なら .is-read（読了印）。印は実DOM要素で挿す（::after だと
    // .th-theme-resident-choice など独自の ::before/::after 演出を使う扉と衝突し、
    // 詳細度の高い方が background 等を丸ごと上書きしてしまうため）。
    for (const el of document.querySelectorAll<HTMLElement>("[data-slug]")) {
      if (!readSet.has(el.dataset.slug ?? "")) continue;
      el.classList.add("is-read");
      const stamp = document.createElement("span");
      stamp.className = "th-read-stamp";
      stamp.textContent = "読了";
      el.appendChild(stamp);
    }

    // 集計カード: そのカードが束ねる読むページ群のうち何本読み終えたかを出す。
    for (const el of document.querySelectorAll<HTMLElement>("[data-read-group]")) {
      const members = (el.dataset.readGroup ?? "").split(",").filter(Boolean);
      if (members.length === 0) continue;
      const readCount = members.filter((s) => readSet.has(s)).length;
      const badge = el.querySelector<HTMLElement>("[data-read-count]");
      if (badge) {
        badge.textContent = `${readCount}/${members.length} 完読`;
        badge.hidden = false;
      }
      const gaugeFill = el.querySelector<HTMLElement>(".th-read-gauge__fill");
      if (gaugeFill) {
        gaugeFill.style.width = `${readRatioPercent(readCount, members.length)}%`;
      }
      if (readCount === members.length) el.classList.add("is-read-all");
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", applyReadMarks);
  } else {
    applyReadMarks();
  }
</script>

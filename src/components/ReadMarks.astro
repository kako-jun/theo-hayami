---
// 索引の既読反映（Issue #30・クライアント専用）。描画後に localStorage の既読集合を読み、
// - 個別セル（`data-slug="業__住人"`）で既読のものに `.is-read` を付ける（暗くせず、金の灯り＋金の「完読」蔵書印＝達成の印）。
// - 集計カード（`data-read-group="slug,slug,..."`）で既読数を数え、`[data-read-count]` に「N/M 読了」を出し、
//   同じカード内の `.th-read-gauge__fill` の幅も進捗率で更新する（Issue #73）。
//   全部読み終えたカードには `.is-read-all` を付け、個別扉と同じ右上の完読印（`.th-read-stamp`）を出す（右下ゲージと共存）。
// - 本編進行で消えた住人の自由行動ボタン（`data-resident-choice`）には `.is-disappeared` を付け、
//   href を外して選べなくする。DEAD 表記や灰色化ではなく、階調反転で「現実に侵食してきた」違和感を出す。
// localStorage はクライアント専用なので必ず描画後（module script は defer で DOM 構築後に走る）に実行する。
//
// import で readStore.ts を使い、キー/形式の二重定義を避ける（唯一の正本＝readStore.ts）。
// このコンポーネントは索引ページに1つ置けばよい（Astro が module script を1回だけ束ねる）。
//
// 集計カードの分数バッジは途中経過なので「読了」。分子=分母の到達状態が「完読」。
---

<script>
  import { getReadSet, readRatioPercent } from "../lib/readStore";
  import { getStoredDisappearedResidents } from "../lib/storyProgress";

  function applyReadMarks() {
    const readSet = getReadSet();

    // 個別セル: 既読なら .is-read（完読印）。印は実DOM要素で挿す（::after だと
    // .th-theme-resident-choice など独自の ::before/::after 演出を使う扉と衝突し、
    // 詳細度の高い方が background 等を丸ごと上書きしてしまうため）。
    for (const el of document.querySelectorAll<HTMLElement>("[data-slug]")) {
      if (!readSet.has(el.dataset.slug ?? "")) continue;
      el.classList.add("is-read");
      // 冪等ガード: applyReadMarks の再実行でも完読印を二重に挿さない（集計ループと対称）。
      if (el.querySelector(".th-read-stamp")) continue;
      const stamp = document.createElement("span");
      stamp.className = "th-read-stamp";
      stamp.textContent = "完読";
      el.appendChild(stamp);
    }

    // 集計カード: そのカードが束ねる読むページ群のうち何本読み終えたかを出す。
    for (const el of document.querySelectorAll<HTMLElement>("[data-read-group]")) {
      const members = (el.dataset.readGroup ?? "").split(",").filter(Boolean);
      if (members.length === 0) continue;
      const readCount = members.filter((s) => readSet.has(s)).length;
      const badge = el.querySelector<HTMLElement>("[data-read-count]");
      if (badge) {
        badge.textContent = `${readCount}/${members.length} 読了`;
        badge.hidden = false;
      }
      const gaugeFill = el.querySelector<HTMLElement>(".th-read-gauge__fill");
      if (gaugeFill) {
        gaugeFill.style.width = `${readRatioPercent(readCount, members.length)}%`;
      }
      if (readCount === members.length) {
        el.classList.add("is-read-all");
        // 全読了の集計扉にも個別扉と同じ右上の完読印を出す（右下ゲージと共存）。
        // 再実行で二重に付かないよう既存の .th-read-stamp 有無を確認する。
        if (!el.querySelector(".th-read-stamp")) {
          const stamp = document.createElement("span");
          stamp.className = "th-read-stamp";
          stamp.textContent = "完読";
          el.appendChild(stamp);
        }
      }
    }

    const disappeared = new Set(getStoredDisappearedResidents());
    for (const el of document.querySelectorAll<HTMLElement>("[data-resident-choice]")) {
      const resident = el.dataset.residentChoice ?? "";
      if (!disappeared.has(resident)) continue;
      el.classList.add("is-disappeared");
      el.setAttribute("aria-disabled", "true");
      el.setAttribute("tabindex", "-1");
      if (el instanceof HTMLAnchorElement) {
        if (!el.dataset.href) el.dataset.href = el.getAttribute("href") ?? "";
        el.removeAttribute("href");
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", applyReadMarks);
  } else {
    applyReadMarks();
  }
</script>

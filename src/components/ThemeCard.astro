---
import { themeSymbolImage } from "../lib/scripts";

interface Props {
  slug: string;
  title: string;
  /** この業の全読むページ slug（`業__住人`）。既読数バッジ用（Issue #30・クライアントで集計）。 */
  readGroup: string[];
}
const { slug, title, readGroup } = Astro.props;
// 象徴画像（Issue #73）: 画像が実在する業だけ背景に敷く。今のところ netami のみ。
const symbolImage = themeSymbolImage(slug);
---

<a
  href={`/themes/${slug}`}
  class={`th-door block no-underline${symbolImage ? " th-door--symbol" : ""}`}
  style={symbolImage ? `background-image: url(${symbolImage})` : undefined}
  data-read-group={readGroup.join(",")}
>
  <p class="text-base leading-relaxed" style="color: var(--color-th-ivory);">{title}</p>
  <div class="th-read-meter">
    <span class="th-read-gauge" aria-hidden="true"><span class="th-read-gauge__fill"></span></span>
    <p class="th-read-badge text-xs" data-read-count>{`0/${readGroup.length} 読了`}</p>
  </div>
</a>

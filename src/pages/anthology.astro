---
import Breadcrumb from "../components/Breadcrumb.astro";
import ReadMarks from "../components/ReadMarks.astro";
import ResidentCard from "../components/ResidentCard.astro";
import LibraryLayout from "../layouts/LibraryLayout.astro";
import { RESIDENTS } from "../data/residents";
import { loadCharacterThemes } from "../lib/scripts";

const characterThemes = loadCharacterThemes();
// 住人ごとの読むページ slug 群（`業__住人`）。クライアント（ReadMarks）が既読数を集計する。
const readGroups = new Map(characterThemes.map((c) => [c.slug, c.themes.map((t) => `${t}__${c.slug}`)]));
---

<LibraryLayout
  title="住人から選ぶ ── せおはやみ"
  description="叡智の星海の住人8人。誰に、どの業を聞くか選ぶ索引。"
  bgImage="shadow-library/grand-reading-room-v.webp"
>
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "叡智の星海", href: "/" }, { label: "業から引く" }]} />

    <header class="text-center my-8 th-glow">
      <h1 class="text-2xl sm:text-3xl" style="color: var(--color-th-theo);">住人から選ぶ</h1>
      <p class="mt-2 text-sm" style="color: var(--color-th-ivory-dim);">
        顔を見て、聞いてみたい住人を選んでください。
      </p>
      <a href="/themes" class="th-link-button inline-block mt-4 no-underline">業から選ぶ</a>
    </header>

    <div class="th-grid">
      {
        RESIDENTS.map((resident) => (
          <ResidentCard
            resident={resident}
            readGroup={readGroups.get(resident.slug) ?? []}
          />
        ))
      }
    </div>
  </div>
  <ReadMarks />
</LibraryLayout>

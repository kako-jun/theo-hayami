---
import Breadcrumb from "../../components/Breadcrumb.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import ReaderFrame from "../../components/ReaderFrame.astro";
import { featuredTeaTimeQuestion } from "../../data/teaTime";
---

<LibraryLayout
  title={`${featuredTeaTimeQuestion.title} ── けふのティータイム`}
  description={featuredTeaTimeQuestion.question}
  bgImage="shadow-library/history-hall.webp"
>
  <div class="max-w-4xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[
        { label: "トップ", href: "/" },
        { label: "けふのティータイム", href: "/tea-time" },
        { label: featuredTeaTimeQuestion.title },
      ]}
    />

    <section class="th-magazine-section mt-8">
      <p class="th-magazine-section__folio">004-01 / TEA TIME</p>
      <h1>{featuredTeaTimeQuestion.title}</h1>
      <p>{featuredTeaTimeQuestion.question}</p>
    </section>

    <section class="th-panel mt-8">
      <p class="text-sm leading-loose" style="color: var(--color-th-ivory-dim);">
        この話題では、マキヤ・スピノ・オウの三人がお茶の席につきます。
      </p>
    </section>

    <section class="mt-8">
      <ReaderFrame
        slug="tea-world-cup"
        sceneId="tea-wc-luck"
        title={featuredTeaTimeQuestion.title}
      />
    </section>
  </div>
</LibraryLayout>

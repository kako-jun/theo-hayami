---
import Breadcrumb from "../../components/Breadcrumb.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import ReaderFrame from "../../components/ReaderFrame.astro";
import { featuredTeaTimeQuestion } from "../../data/teaTime";
import { findResident } from "../../data/residents";

// この話題でお茶の席につく住人（residents.ts から name/ability を引く）。
const speakers = (featuredTeaTimeQuestion.residents ?? [])
  .map((slug) => findResident(slug))
  .filter((r): r is NonNullable<typeof r> => r !== undefined);
---

<LibraryLayout
  title={`${featuredTeaTimeQuestion.title} ── けふのティータイム`}
  description={featuredTeaTimeQuestion.question}
  bgImage="shadow-library/history-hall.webp"
>
  <div class="max-w-4xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[
        { label: "トップ", href: "/" },
        { label: "けふのティータイム", href: "/tea-time" },
        { label: featuredTeaTimeQuestion.title },
      ]}
    />

    <section class="th-magazine-section th-magazine-section--plain mt-8" style="border-bottom: 0; padding-bottom: 0;">
      <p class="th-magazine-section__folio">004-01 / TEA TIME</p>
      <h1 class="mt-2">{featuredTeaTimeQuestion.title}</h1>
    </section>

    <figure class="th-tea-quote th-glow mt-6">
      <span class="th-tea-mark" aria-hidden="true">Q</span>
      <blockquote>「{featuredTeaTimeQuestion.question}」</blockquote>
    </figure>

    <hr class="th-tea-rule mt-6" aria-hidden="true" />

    <div class="th-tea-answer th-glow mt-6">
      <span class="th-tea-mark" aria-hidden="true">A</span>
      {
        speakers.length > 0 && (
          <ul class="th-tea-speakers">
            {speakers.map((r) => (
              <li class="th-tea-speaker">
                <span class="th-tea-speaker__face">
                  <img
                    src={`/images/theme-residents/${r.slug}.webp`}
                    alt={r.name}
                    loading="lazy"
                  />
                </span>
                <span class="th-tea-speaker__name">{r.name}</span>
                <span class="th-tea-speaker__meta">叡智：{r.ability}</span>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <div class="mt-8">
      <ReaderFrame
        slug="tea-world-cup"
        sceneId="tea-wc-luck"
        title={featuredTeaTimeQuestion.title}
      />
    </div>

    <nav class="grid gap-3 sm:grid-cols-2 mt-10" aria-label="このあと">
      <a href="/tea-time" class="th-link-button text-center no-underline">けふのティータイム</a>
    </nav>
  </div>
</LibraryLayout>

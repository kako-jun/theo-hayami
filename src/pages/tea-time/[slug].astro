---
import { existsSync, readFileSync } from "node:fs";
import path from "node:path";
import Breadcrumb from "../../components/Breadcrumb.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import ReaderFrame from "../../components/ReaderFrame.astro";
import type { TeaTimeQuestion } from "../../data/teaTime";
import { publishedTeaTimeQuestions } from "../../data/teaTime";
import { findResident } from "../../data/residents";
import { keepsTerminalEventImage } from "../../lib/scripts";

export function getStaticPaths() {
  return publishedTeaTimeQuestions.map((question, index) => ({
    params: { slug: question.slug },
    props: { question, index },
  }));
}

const { question, index } = Astro.props as { question: TeaTimeQuestion; index: number };
const speakers = (question.residents ?? [])
  .map((slug) => findResident(slug))
  .filter((r): r is NonNullable<typeof r> => r !== undefined);
const sceneId = question.sceneId ?? `tea-${question.slug}`;
const teaNumber = String(question.number ?? index + 1).padStart(2, "0");
const currentScriptsDir = path.join(process.cwd(), "content", "scripts", "current");
const scriptCandidates = [
  path.join(currentScriptsDir, `${question.slug}.md`),
  path.join(currentScriptsDir, `${sceneId.replace(/^tea-/, "")}.md`),
];
const scriptPath = scriptCandidates.find((candidate) => existsSync(candidate));
const keepTerminalEventImage = scriptPath ? keepsTerminalEventImage(readFileSync(scriptPath, "utf-8")) : false;
---

<LibraryLayout
  title={`${question.title} ── けふのティータイム`}
  description={question.question}
  bgImage="shadow-library/history-hall.webp"
  ogImage="promotional/cast/tea-time-cast.webp"
>
  <div class="max-w-4xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[
        { label: "トップ", href: "/" },
        { label: "けふのティータイム", href: "/tea-time" },
        { label: question.title },
      ]}
    />

    <section class="th-magazine-section th-magazine-section--plain mt-8" style="border-bottom: 0; padding-bottom: 0;">
      <p class="th-magazine-section__folio">004-{teaNumber} / TEA TIME</p>
      <h1 class="mt-2">{question.title}</h1>
    </section>

    <figure class="th-tea-quote th-glow mt-6">
      <span class="th-tea-mark" aria-hidden="true">Q</span>
      <blockquote>「{question.question}」</blockquote>
    </figure>

    <hr class="th-tea-rule mt-6" aria-hidden="true" />

    <div class="th-tea-answer th-glow mt-6">
      <span class="th-tea-mark" aria-hidden="true">A</span>
      {
        speakers.length > 0 && (
          <ul class="th-tea-speakers">
            {speakers.map((r) => (
              <li class="th-tea-speaker" data-resident={r.slug}>
                <span class="th-tea-speaker__face">
                  <img
                    src={`/images/theme-residents/${r.slug}.webp`}
                    alt={r.name}
                    loading="lazy"
                  />
                </span>
                <span class="th-tea-speaker__name">{r.name}</span>
                <span class="th-tea-speaker__meta">叡智：{r.ability}</span>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <div class="mt-8">
      <ReaderFrame
        slug={`tea-${question.slug}`}
        sceneId={sceneId}
        title={question.title}
        markReadOnStart={keepTerminalEventImage}
      />
    </div>

    <nav class="th-page-nav mt-10" aria-label="このあと">
      <a href="/tea-time" class="th-link-button no-underline">けふのティータイム</a>
    </nav>
  </div>
</LibraryLayout>

---
// 星海への接続端末（Issue #131）。/tea-time の下の参加型サブページ。
// - 上部: 推したい住人ランキング（自前レンダリング）。
//   kako-jun 指摘: `<nostalgic-ranking>` の read-only widget は name/score/rankの
//   テキストのみで住人の顔を出せずピンとこない。widget表示は廃止し、住人8人固定で
//   顔アップ・順位・名前・スコア・投票ボタンの行を自前で組む。API とのやり取り
//   （get→+1→submit）は widget時代のロジックをそのまま流用する。
// - 下部: ティータイムのお題を投稿できるBBS（Nostalgic BBS。post機能込みの単一widgetをそのまま埋め込む）
// 004 / TEA TIME の枝ページ。folio番号は独立させない（Issue #131 本文の指示）。
import Breadcrumb from "../../components/Breadcrumb.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import { VOTE_TARGETS } from "../../lib/rankingVote";

// kako-jun 指示（Issue #131追記）: 投票対象の「住人」にせお・ヴィンチアも含める
// （「2人だって住人だ」という世界観解釈）。見出し「推したい住人を選んでね」は
// 変更不要（せお・ヴィンチアも住人に含まれるため、このままで正確）。
// buildResidentRankingRows は {slug, name}[] の汎用シグネチャなので変更不要。
// VOTE_TARGETS（住人8人+EXTRA_VOTE_TARGETS）は rankingVote.ts 側の1箇所で組み立て済み
// （frontmatterとclient scriptで個別に組み立てると将来食い違うため、ここではimportのみ）。
// 全10人を bust.webp で統一表示するため、せお・ヴィンチアの暫定分岐(isExtra)は撤廃。

// BBS は投票ロジックを持たず、この widget 属性でしか使わないためローカル定数でよい
// （Nostalgic側で作成済み・再作成不要。Nostalgic の公開IDはURLのみから生成されサービス種別を
// 含まないため、同一URL https://theo-hayami.llll-ll.com/tea-time/community で ranking と bbs を
// create すると同じID文字列になるのは必然（偶然ではない）。それぞれ /ranking?id=... と
// /bbs?id=... のエンドポイントで名前空間が分かれているため、動作上の衝突はない）。
const BBS_ID = "theo-hayami-fc727d17";
---

<LibraryLayout
  title="星海への接続端末 ── けふのティータイム"
  description="推したい住人に投票したり、ティータイムのお題を投稿したりできる場所。"
  bgImage="shadow-library/history-hall.webp"
  ogImage="promotional/cast/tea-time-cast.webp"
>
  <div class="max-w-3xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[
        { label: "トップ", href: "/" },
        { label: "けふのティータイム", href: "/tea-time" },
        { label: "星海への接続端末" },
      ]}
    />

    <header class="mt-8 th-glow">
      <p class="th-magazine-section__folio">004 / TEA TIME</p>
      <h1 class="text-2xl sm:text-3xl mt-2" style="color: var(--color-th-theo);">星海への接続端末</h1>
    </header>

    <!-- 導入文は姉妹ページ tea-time.astro と同じ本文規約（.th-story-index__intro=
         0.95rem/2.05/ivory/54rem）＋金ヘアラインの導入ブロックに揃える（kako-jun指摘 #134:
         本文のサイズ/行間/色/余白を本編・けふのティータイムと統一）。 -->
    <section class="th-story-index-intro mt-8">
      <p class="th-story-index__intro">
        住人への一票と、次のお題の投稿を残せる場所です。
      </p>
    </section>

    <!-- 投票UIは枠・箱を持たせず、書庫の地色の上に顔を直接並べる（kako-jun指摘 #134:
         枠もいらない・一つの作品として）。外側の .th-panel の箱は撤去。 -->
    <section class="mt-8">
      <h2 class="text-xl" style="color: var(--color-th-theo);">推したい住人を選んでください</h2>
      <p class="th-story-index__intro mt-4">
        推したい住人に一票どうぞ。何度でも押せますが、連続投票には少し間隔が必要です。
      </p>

      <!-- 全10人（住人8＋せお＋ヴィンチア）を bust.webp で統一表示。ポートレート・カード
           自体が投票トリガー（button）。順位バッジ＋スコアはカード隅にオーバーレイし、
           スコア取得(get)後にJSで反映する（格子は固定順・自動並べ替えはしない）。
           投票ボタンは最初から disabled にしておく: 現在スコアの取得（get）が終わる前に
           投票できてしまうと、findCurrentScoreが0を返して submit?score=1 を送ってしまい、
           既に score>0 の住人ではサーバー側UPSERTが「新スコアが既存より上回るときだけ更新」
           のため無言でno-opになる（submit応答自体は success:true を返すためUIには
           「投票しました」と出てしまう）。取得が終わるまでは押させない。 -->
      <ul class="th-vote-grid" data-vote-list>
        {
          VOTE_TARGETS.map((resident) => (
            <li
              class="th-vote-cell"
              data-vote-row
              data-resident-slug={resident.slug}
              data-resident-name={resident.name}
            >
              <button
                type="button"
                class="th-vote-card"
                data-vote-name={resident.name}
                data-resident-slug={resident.slug}
                aria-label={`${resident.name}に一票を灯す`}
                disabled
              >
                <span class="th-vote-card__portrait th-face-crop th-face-crop--bust">
                  <img src={`/images/${resident.slug}/bust.webp`} alt="" loading="lazy" />
                </span>
                <span class="th-vote-card__name">{resident.name}</span>
                <span class="th-vote-card__score"><span data-vote-score>0</span></span>
              </button>
            </li>
          ))
        }
      </ul>
      <p class="th-vote-status mt-3" role="status" aria-live="polite" data-vote-status></p>
    </section>

    <script>
      import {
        RANKING_ID,
        buildRankingGetUrl,
        buildRankingSubmitUrl,
        findCurrentScore,
        formatVoteWaitMessage,
        mergeRankingEntries,
        parseVoteRateLimitSeconds,
      } from "../../lib/rankingVote";
      import type { RankingEntry } from "../../lib/rankingVote";

      const listEl = document.querySelector<HTMLUListElement>("[data-vote-list]");
      const statusEl = document.querySelector<HTMLElement>("[data-vote-status]");

      if (listEl && statusEl) {
        const list = listEl;
        const status = statusEl;

        // グリッドのセル（li）を slug で引けるようにする。カード内 button にも
        // data-resident-slug が付くため、行の器である [data-vote-row]（li）に限定して拾う。
        const rowsBySlug = new Map<string, HTMLLIElement>();
        for (const li of list.querySelectorAll<HTMLLIElement>("[data-vote-row]")) {
          const slug = li.dataset.residentSlug;
          if (slug) rowsBySlug.set(slug, li);
        }
        const buttons = Array.from(list.querySelectorAll<HTMLButtonElement>("[data-vote-name]"));

        // kako-jun 指摘（Issue #131追記）: APIの action=submit レスポンスは action=get と
        // 同じ形（{success, data:{entries}}）で更新後の entries を含む
        // （nostalgic/docs/user-guide/services/ranking.md と apps/api/src/routes/ranking.ts の
        // 実装 `return c.json({ success: true, data: { id, entries } })` を実際に読んで確認済み）。
        // そのため投票直前の get・投票直後の再get はどちらも不要にできる。
        // 最新の get/submit レスポンスをここへキャッシュし、投票のたびの現在スコア検索は
        // このキャッシュだけを参照する（自分の連続投票は毎回このキャッシュを更新するので
        // 正しく動く。他ユーザーとの同時投票の取りこぼしは低頻度サイトとして許容＝Issue本文の前提通り）。
        let cachedEntries: RankingEntry[] = [];

        function setButtonsDisabled(disabled: boolean) {
          for (const button of buttons) button.disabled = disabled;
        }

        function setStatus(message: string) {
          status.textContent = message;
        }

        // グリッドは固定順（宣言順）で並べたまま、得票数（スコア）だけを各カードの
        // オーバーレイに反映する（DOMの並べ替え＝appendChildはしない＝カード位置は動かない）。
        // kako-jun指摘 #134: #N の順位連番はボタンに不要（初期は通し番号に見えて無意味）なので撤去。
        // スコアだけ出す用途では並べ替え不要なため buildResidentRankingRows は使わない。
        function renderRows(entries: RankingEntry[]) {
          for (const [slug, li] of rowsBySlug) {
            const name = li.dataset.residentName ?? "";
            const scoreEl = li.querySelector<HTMLElement>("[data-vote-score]");
            if (scoreEl) scoreEl.textContent = String(findCurrentScore(entries, name));
            void slug;
          }
        }

        // ページ読み込み時に1回だけ get する（この呼び出し以降、投票のたびの get は行わない）。
        // 投票ボタンはマークアップ側で最初から disabled にしてあるので、ここで成功した
        // ときだけ有効化する（現在スコアが分かる前に投票させて無言no-opにしないため）。
        async function loadInitialRanking() {
          try {
            const res = await fetch(buildRankingGetUrl(RANKING_ID, 100));
            const data: { success?: boolean; data?: { entries?: RankingEntry[] } } = await res.json();
            if (!res.ok || !data.success) {
              setStatus("ランキングの読み込みに失敗しました。ページを再読み込みしてください。");
              return;
            }
            cachedEntries = data.data?.entries ?? [];
            renderRows(cachedEntries);
            setButtonsDisabled(false);
          } catch {
            // 取得に失敗した場合はボタンを disabled のまま残す（レイアウトは壊れない）。
            setStatus("ランキングの読み込みに失敗しました。ページを再読み込みしてください。");
          }
        }

        // signature 演出: 投票成功時、その顔の背後に一度だけ金の光が広がる（is-lit を
        // 付け直してアニメーションを再生。連続投票でも毎回灯るよう一旦外して次フレームで付ける）。
        function lightUp(button: HTMLButtonElement) {
          button.classList.remove("is-lit");
          // reflow を挟んでからクラスを付け直すとアニメーションが再スタートする。
          void button.offsetWidth;
          button.classList.add("is-lit");
        }

        async function vote(name: string, button: HTMLButtonElement) {
          setButtonsDisabled(true);
          setStatus(`${name}に投票しています…`);
          try {
            const currentScore = findCurrentScore(cachedEntries, name);
            const submitRes = await fetch(buildRankingSubmitUrl(RANKING_ID, name, currentScore + 1));
            const submitData: { success?: boolean; data?: { entries?: RankingEntry[] }; error?: string } =
              await submitRes.json();

            if (submitRes.status === 429) {
              const seconds = parseVoteRateLimitSeconds(submitData.error ?? "");
              setStatus(
                seconds !== null
                  ? formatVoteWaitMessage(seconds)
                  : "投票が集中しています。しばらくしてからもう一度お試しください。"
              );
              return;
            }

            if (!submitRes.ok || !submitData.success) {
              setStatus("投票に失敗しました。しばらくしてからもう一度お試しください。");
              return;
            }

            // submit のレスポンスに含まれる更新後の entries をキャッシュへマージする
            // （追加の get は呼ばない＝API呼び出しは submit の1回だけ。「丸ごと置換」ではなく
            // マージにする理由は mergeRankingEntries のコメント参照）。
            cachedEntries = mergeRankingEntries(cachedEntries, submitData.data?.entries ?? []);
            setStatus(`${name}に一票を灯しました。`);
            renderRows(cachedEntries);
            lightUp(button);
          } catch {
            setStatus("投票に失敗しました。通信状況をご確認ください。");
          } finally {
            setButtonsDisabled(false);
          }
        }

        for (const button of buttons) {
          const name = button.dataset.voteName;
          if (!name) continue;
          button.addEventListener("click", () => {
            void vote(name, button);
          });
        }

        // 初期表示: プレースホルダ（宣言順・スコア0）を実データへ更新する（get 1回）。
        void loadInitialRanking();
      }
    </script>

    <!-- BBSウィジェット自身が保存タイトル「ティータイムのお題を募集」をヘッダとして
         描画するため、外側の .th-panel の箱と重複する <h2> は撤去し、枠なしで直接置く
         （kako-jun指摘 #134: タイトル二重・箱過剰）。説明文と mt-10 のセクション間隔は維持。 -->
    <section class="mt-10">
      <p class="th-story-index__intro">
        次のお茶の席で扱ってほしい話題を書き込めます。名前は省略できます。
      </p>
      <div class="mt-5">
        <!-- nostalgic-bbs は Shadow DOM だが CSSカスタムプロパティは継承で境界を越えるため、
             インライン style で theo 書庫パレットに寄せて上書きする（インラインは内部 :host
             既定に勝つ）。theme="dark" は土台として残し、その上に変数を被せる。
             nostalgicサーバー/コンポーネント側は一切変更しない。 -->
        <nostalgic-bbs
          id={BBS_ID}
          theme="dark"
          lang="ja"
          width="100%"
          style="
            --bbs-bg-color: #12111a;
            --bbs-border-color: #b8934f;
            --bbs-shadow-color: rgba(10, 9, 16, 0.8);
            --bbs-header-bg: #0a0910;
            --bbs-header-color: #f1e8d6;
            --bbs-message-bg: #1a1826;
            --bbs-text-color: #f1e8d6;
            --bbs-scrollbar-thumb: #b8934f;
            --bbs-scrollbar-hover: #e6c47e;
          "></nostalgic-bbs>
      </div>
      <!-- 読み込みに失敗しても <nostalgic-bbs> は中身が空のまま静かに残るだけで
           レイアウトは壊れない（VisitorCounter.astro と同じ is:inline パターン）。 -->
      <script is:inline src="https://nostalgic.llll-ll.com/components/bbs.js" defer></script>
    </section>

    <nav class="th-page-nav mt-10" aria-label="このあと">
      <a href="/tea-time" class="th-link-button no-underline">けふのティータイム</a>
    </nav>
  </div>
</LibraryLayout>

---
import Breadcrumb from "../../components/Breadcrumb.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import ReadMarks from "../../components/ReadMarks.astro";
import { RESIDENTS, findResident } from "../../data/residents";
import { findOhako, loadCharacterThemes, loadThemes } from "../../lib/scripts";

export function getStaticPaths() {
  return RESIDENTS.map((resident) => ({
    params: { character: resident.slug },
  }));
}

const { character } = Astro.params;
const resident = findResident(character);
// getStaticPaths は RESIDENTS からしか params を作らないため、ここに来る時点で必ず見つかる。
if (!resident) {
  throw new Error(`未知の住人スラッグ: ${character}`);
}

const themeSlugs = new Set(loadCharacterThemes().find((c) => c.slug === character)?.themes ?? []);
// 業の日本語名・並び順はハブ(script.md)正本の loadThemes() から引く。
const themes = loadThemes().filter((t) => themeSlugs.has(t.slug));
// この住人の「初めての問答（おはこ）」への恒久導線（Issue #41）。無ければ節ごと出さない。
const ohako = findOhako(character);
---

<LibraryLayout
  title={`${resident.name} ── せおはやみ`}
  description={`${resident.name}（能力：${resident.ability}）。${resident.blurb}`}
  bgImage="shadow-library/grand-reading-room-v.webp"
>
  <div class="max-w-3xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[{ label: "影の図書館", href: "/" }, { label: "業から引く", href: "/anthology" }, { label: resident.name }]}
    />

    <header class="th-resident-feature my-8">
      <img
        src={`/images/promotional/residents/${resident.slug}-feature.webp`}
        alt=""
        width="1672"
        height="941"
        loading="eager"
      />
      <div class="th-resident-feature__copy th-glow">
        <p class="th-resident-feature__kicker">Resident File / {resident.slug}</p>
        <h1 class="sr-only">{resident.name}</h1>
        <img
          src={`/images/nameplates/ja/${resident.slug}.webp`}
          alt=""
          class="th-resident-feature__nameplate"
          loading="eager"
          aria-hidden="true"
        />
        <p class="th-resident-feature__ability">能力：{resident.ability}（{resident.thought}）</p>
      </div>
    </header>

    <section class="th-magazine-section th-magazine-section--compact mb-10">
      <p class="th-magazine-section__folio">{resident.origin}</p>
      <p>{resident.blurb}</p>
    </section>

    {
      ohako && (
        <section class="mb-10">
          <h2 class="text-base mb-3" style="color: var(--color-th-gold-bright);">
            はじめての問答（おはこ）
          </h2>
          {/* data-slug は ReaderFrame が完読時に markRead する slug（= ohako.slug = `ohako-${character}`）
              と同一。free の扉と同じ規約で ReadMarks が既読なら金の読了印（.th-door.is-read）を付ける。 */}
          <a href={`/main/${ohako.slug}`} data-slug={ohako.slug} class="th-door block no-underline">
            <p style="color: var(--color-th-ivory);">{ohako.title}</p>
            <p class="text-xs mt-2" style="color: var(--color-th-ivory-dim);">
              {resident.name}が、せおと初めて交わした問答
            </p>
          </a>
        </section>
      )
    }

    <h2 class="text-base mb-3" style="color: var(--color-th-gold-bright);">
      {resident.name}が答える業（{themes.length}）
    </h2>
    <ul class="th-theme-grid">
      {
        themes.map((theme) => (
          <li>
            <a
              href={`/free/${theme.slug}__${resident.slug}`}
              data-slug={`${theme.slug}__${resident.slug}`}
              class="th-door block no-underline"
            >
              <p style="color: var(--color-th-ivory);">{theme.title}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <ReadMarks />
</LibraryLayout>

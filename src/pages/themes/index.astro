---
import Breadcrumb from "../../components/Breadcrumb.astro";
import ReadMarks from "../../components/ReadMarks.astro";
import ThemeCard from "../../components/ThemeCard.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import { loadThemeCategories } from "../../lib/scripts";

const themeCategories = loadThemeCategories();
---

<LibraryLayout
  title="業から選ぶ ── せおはやみ"
  description="人が時を超えて抱え続ける業（テーマ）の一覧。答える住人が違う。"
  bgImage="shadow-library/grand-reading-room-v.webp"
>
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "トップ", href: "/" }, { label: "業から引く", href: "/anthology" }, { label: "業から選ぶ" }]} />

    <header class="text-center my-8 th-glow">
      <h1 class="text-2xl sm:text-3xl" style="color: var(--color-th-theo);">業から選ぶ</h1>
      <p class="mt-2 text-sm" style="color: var(--color-th-ivory-dim);">
        棚に並んでいるのは、時を超えても人が抱え続けるお題。今、扉が開いているのはどれだろう。
      </p>
      <a href="/anthology" class="th-link-button inline-block mt-4 no-underline">住人から選ぶ</a>
    </header>

    <div class="th-theme-category-list">
      {
        themeCategories.map(({ category, themes }, index) => (
          <section class="th-theme-category" aria-labelledby={`theme-category-${category.slug}`}>
            <div class="th-theme-category__head">
              <p class="th-magazine-section__folio">{`CATEGORY ${String(index + 1).padStart(2, "0")}`}</p>
              <h2 id={`theme-category-${category.slug}`}>{category.label}</h2>
              <p>{category.description}</p>
            </div>
            <div class="th-theme-grid">
              {
                themes.map((theme) => (
                  <ThemeCard
                    slug={theme.slug}
                    title={theme.title}
                    readGroup={theme.characters.map((c) => `${theme.slug}__${c}`)}
                  />
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </div>
  <ReadMarks />
</LibraryLayout>

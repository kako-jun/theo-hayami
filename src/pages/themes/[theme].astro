---
import Breadcrumb from "../../components/Breadcrumb.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import ReadMarks from "../../components/ReadMarks.astro";
import { RESIDENTS } from "../../data/residents";
import { loadThemes } from "../../lib/scripts";

export function getStaticPaths() {
  return loadThemes().map((theme) => ({
    params: { theme: theme.slug },
    props: { theme },
  }));
}

const { theme } = Astro.props;

// 表示順は住人プロフィールの正典順（character_bible.md）で揃え、
// このお題に実在する組み合わせだけに絞る（存在しない組み合わせは出さない＝カバレッジ地図）。
const residents = RESIDENTS.filter((r) => theme.characters.includes(r.slug));
---

<LibraryLayout
  title={`${theme.title} ── せおはやみ`}
  description={`「${theme.title}」という業に、叡智の星海の住人たちがそれぞれの思想で答える。`}
  bgImage="shadow-library/grand-reading-room-v.webp"
>
  <div class="max-w-3xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[
        { label: "叡智の星海", href: "/" },
        { label: "業から引く", href: "/anthology" },
        { label: "業から選ぶ", href: "/themes" },
        { label: theme.title },
      ]}
    />

    <header class="text-center my-8 th-glow">
      <h1 class="text-2xl sm:text-3xl" style="color: var(--color-th-theo);">「{theme.title}」</h1>
      <p class="mt-2 text-sm" style="color: var(--color-th-ivory-dim);">この業を、誰に訊いてみよう。</p>
    </header>

    <ul class="grid gap-3 sm:grid-cols-2">
      {
        residents.map((resident) => (
          <li>
            <a
              href={`/free/${theme.slug}__${resident.slug}`}
              data-slug={`${theme.slug}__${resident.slug}`}
              data-resident={resident.slug}
              class="th-door th-theme-resident-choice block no-underline"
            >
              <img
                class="th-theme-resident-choice__image"
                src={`/images/theme-residents/${resident.slug}.webp`}
                alt=""
                loading="lazy"
              />
              <span class="th-theme-resident-choice__body">
                <span class="th-theme-resident-choice__name">{resident.name}に訊く</span>
                <span class="th-theme-resident-choice__meta">叡智：{resident.ability}（{resident.thought}）</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <ReadMarks />
</LibraryLayout>

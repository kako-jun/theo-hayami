---
import Breadcrumb from "../components/Breadcrumb.astro";
import LibraryLayout from "../layouts/LibraryLayout.astro";
import ReadMarks from "../components/ReadMarks.astro";
import { publishedTeaTimeQuestions, teaTimeQuestions } from "../data/teaTime";
import { findResident } from "../data/residents";

// 索引の話者紹介文は各話題の residents 配列から生成する（二重管理を避ける）。
const teaNumber = (number: number | undefined) => String(number ?? 0).padStart(2, "0");
const speakerLine = (residents: string[] | undefined) => {
  const names = (residents ?? [])
    .map((slug) => findResident(slug)?.name)
    .filter((name): name is string => Boolean(name));
  return names.length > 0
    ? `${names.join("・")}の${names.length}人がお茶の席につきます。`
    : "住人たちがお茶の席につきます。";
};
---

<LibraryLayout
  title="けふのティータイム ── せおはやみ"
  description="時事的な問いが、住人たちのお茶の席に並ぶ更新コーナー。"
  bgImage="shadow-library/history-hall.webp"
  ogImage="promotional/cast/tea-time-cast.webp"
>
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "トップ", href: "/" }, { label: "けふのティータイム" }]} />

    <section class="th-story-opening mt-8">
      <img
        src="/images/promotional/cast/tea-time-cast.webp"
        alt=""
        loading="eager"
      />
      <div class="th-story-opening__copy th-glow">
        <p class="th-magazine-section__folio">004 / TEA TIME</p>
        <h1>けふのティータイム</h1>
      </div>
    </section>

    <section class="th-story-index-intro mt-8">
      <p class="th-story-index__intro">
        時事的な問いが、住人たちのお茶の席に並ぶ場所です。
        本編や自由行動のように一人へ答えを求めるのではなく、いくつかの視点をお茶の席に並べます。
      </p>
    </section>

    <section class="mt-8">
      <a href="/tea-time/community" class="th-terminal-portal no-underline">
        <span class="th-terminal-portal__body">
          <span class="th-terminal-portal__label">星海への接続端末</span>
          <span class="th-terminal-portal__desc">
            推したい住人に一票を灯したり、ティータイムのお題を投稿したりできます。
          </span>
        </span>
        <span class="th-terminal-portal__cue" aria-hidden="true">星海をひらく</span>
      </a>
    </section>

    <section class="mt-10">
      <h2 class="text-base mb-3 th-glow" style="color: var(--color-th-gold-bright);">公開中の話題</h2>
      <ol class="grid gap-3">
        {
          publishedTeaTimeQuestions.map((entry) => (
            <li>
              <a
                href={`/tea-time/${entry.slug}`}
                data-slug={`tea-${entry.slug}`}
                class="th-door th-current-question th-current-question--featured block no-underline"
              >
                <span class="th-story-button__number">{teaNumber(entry.number)}</span>
                <p class="text-base" style="color: var(--color-th-ivory);">{entry.title}</p>
                <p class="text-sm mt-2" style="color: var(--color-th-ivory-dim);">{entry.question}</p>
                <p class="text-xs mt-3" style="color: var(--color-th-gold-bright);">{speakerLine(entry.residents)}</p>
              </a>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="mt-10">
      <h2 class="text-base mb-3 th-glow" style="color: var(--color-th-gold-bright);">待機中の話題</h2>
      <ol class="grid gap-3">
        {
          teaTimeQuestions.map((entry) => (
            <li class="th-door th-current-question th-current-question--pending">
              <span class="th-story-button__number">待</span>
              <p style="color: var(--color-th-ivory);">{entry.title}</p>
              <p class="text-sm mt-2" style="color: var(--color-th-ivory-dim);">{entry.question}</p>
              <p class="text-xs mt-3" style="color: var(--color-th-gold-bright);">
                まだお茶の席には出ていない話題です。
              </p>
            </li>
          ))
        }
      </ol>
    </section>
  </div>

  <ReadMarks />
</LibraryLayout>

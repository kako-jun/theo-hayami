---
import Breadcrumb from "../components/Breadcrumb.astro";
import LibraryLayout from "../layouts/LibraryLayout.astro";
import ReadMarks from "../components/ReadMarks.astro";
import { featuredTeaTimeQuestion, teaTimeQuestions } from "../data/teaTime";
import { findResident } from "../data/residents";

// 索引の話者紹介文は world-cup 側と同じ residents 配列から生成する（二重管理を避ける）。
const featuredNames = (featuredTeaTimeQuestion.residents ?? [])
  .map((slug) => findResident(slug)?.name)
  .filter((name): name is string => Boolean(name));
const featuredSpeakerLine =
  featuredNames.length > 0
    ? `${featuredNames.join("・")}の${featuredNames.length}人がお茶の席につきます。`
    : "住人たちがお茶の席につきます。";
---

<LibraryLayout
  title="けふのティータイム ── せおはやみ"
  description="時事的な問いが、住人たちのお茶の席に並ぶ更新コーナー。"
  bgImage="shadow-library/history-hall.webp"
>
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "トップ", href: "/" }, { label: "けふのティータイム" }]} />

    <section class="th-story-opening mt-8">
      <img
        src="/images/promotional/cast/tea-time-cast.webp"
        alt=""
        loading="eager"
      />
      <div class="th-story-opening__copy th-glow">
        <p class="th-magazine-section__folio">004 / TEA TIME</p>
        <h1>けふのティータイム</h1>
      </div>
    </section>

    <section class="th-story-index-intro mt-8">
      <p class="th-story-index__intro">
        時事的な問いが、住人たちのお茶の席に並ぶ場所です。
        本編や自由行動のように一人へ答えを求めるのではなく、いくつかの視点をお茶の席に並べます。
      </p>
    </section>

    <section class="mt-10">
      <h2 class="text-base mb-3 th-glow" style="color: var(--color-th-gold-bright);">第一弾</h2>
      <a href={`/tea-time/${featuredTeaTimeQuestion.slug}`} data-slug="tea-world-cup" class="th-door th-current-question th-current-question--featured block no-underline">
        <span class="th-story-button__number">01</span>
        <p class="text-base" style="color: var(--color-th-ivory);">{featuredTeaTimeQuestion.title}</p>
        <p class="text-sm mt-2" style="color: var(--color-th-ivory-dim);">{featuredTeaTimeQuestion.question}</p>
        <p class="text-xs mt-3" style="color: var(--color-th-gold-bright);">{featuredSpeakerLine}</p>
      </a>
    </section>

    <section class="mt-10">
      <h2 class="text-base mb-3 th-glow" style="color: var(--color-th-gold-bright);">待機中の話題</h2>
      <ol class="grid gap-3">
        {
          teaTimeQuestions.map((entry, index) => (
            <li class="th-door th-current-question th-current-question--pending">
              <span class="th-story-button__number">{String(index + 2).padStart(2, "0")}</span>
              <p style="color: var(--color-th-ivory);">{entry.title}</p>
              <p class="text-sm mt-2" style="color: var(--color-th-ivory-dim);">{entry.question}</p>
              <p class="text-xs mt-3" style="color: var(--color-th-gold-bright);">
                まだお茶の席には出ていない話題です。
              </p>
            </li>
          ))
        }
      </ol>
    </section>
  </div>

  <ReadMarks />
</LibraryLayout>

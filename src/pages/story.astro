---
import Breadcrumb from "../components/Breadcrumb.astro";
import LibraryLayout from "../layouts/LibraryLayout.astro";
import ReadMarks from "../components/ReadMarks.astro";
import { findResident } from "../data/residents";
import { loadStoryButtons } from "../lib/scripts";

const storyButtons = loadStoryButtons();
const storyIds = storyButtons.map((entry) => entry.slug);
const firstStoryId = storyIds[0] ?? "";
---

<LibraryLayout
  title="物語を辿る ── せおはやみ"
  description="せおはやみ本編。ひとつ読み終えるたびに次の書架が開きます。"
  bgImage="shadow-library/history-hall.webp"
>
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "トップ", href: "/" }, { label: "物語を辿る" }]} />

    <section class="th-story-opening mt-8">
      <img
        src="/images/promotional/cast/story-opening.webp"
        alt=""
        loading="eager"
      />
      <div class="th-story-opening__copy th-glow">
        <p class="th-magazine-section__folio">002 / STORY</p>
        <h1>物語を辿る</h1>
      </div>
    </section>

    <section class="mt-12" data-story-index data-story-ids={JSON.stringify(storyIds)}>
      <p class="th-story-index__intro">
        ひとつ読み終えると、次の書架が開きます。各住人との初めての問答も、序盤の本編としてここから辿ります。
      </p>
      <h2 class="text-base mb-3 th-glow" style="color: var(--color-th-gold-bright);">第一幕　はじめての問答</h2>
      <ol class="th-story-button-grid">
        {
          storyButtons.map((entry) => {
            const resident = findResident(entry.character);
            const initiallyUnlocked = entry.slug === firstStoryId;
            return (
              <li>
                <a
                  href={initiallyUnlocked ? `/main/${entry.slug}` : undefined}
                  data-href={`/main/${entry.slug}`}
                  data-story-link={entry.slug}
                  data-slug={entry.slug}
                  class:list={["th-door th-story-button block no-underline", !initiallyUnlocked && "is-locked"]}
                  aria-disabled={initiallyUnlocked ? "false" : "true"}
                >
                  <span class="th-story-button__number">{String(entry.orderInAct).padStart(2, "0")}</span>
                  <p style="color: var(--color-th-ivory);">{entry.title}</p>
                  {resident && (
                    <p class="text-xs mt-2" style="color: var(--color-th-ivory-dim);">
                      {resident.name}（叡智：{resident.ability}）
                    </p>
                  )}
                  <span class="th-story-button__lock" data-story-lock-label>
                    {initiallyUnlocked ? "解放中" : "未解放"}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ol>
    </section>
  </div>
  <ReadMarks />
</LibraryLayout>

<script>
  import { getStoryProgress } from "../lib/storyProgress";

  function applyStoryGate() {
    const root = document.querySelector<HTMLElement>("[data-story-index]");
    if (!root) return;
    const storyIds = JSON.parse(root.dataset.storyIds ?? "[]") as string[];
    const progress = getStoryProgress(storyIds);
    const unlocked = new Set(progress.unlockedStoryIds);

    for (const link of root.querySelectorAll<HTMLAnchorElement>("[data-story-link]")) {
      const storyId = link.dataset.storyLink ?? "";
      const isUnlocked = unlocked.has(storyId);
      link.classList.toggle("is-locked", !isUnlocked);
      link.setAttribute("aria-disabled", isUnlocked ? "false" : "true");
      if (isUnlocked) {
        link.href = link.dataset.href ?? link.href;
      } else {
        link.removeAttribute("href");
      }
      const label = link.querySelector<HTMLElement>("[data-story-lock-label]");
      if (label) label.textContent = isUnlocked ? "解放中" : "未解放";
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", applyStoryGate);
  } else {
    applyStoryGate();
  }
</script>

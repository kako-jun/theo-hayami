---
import Breadcrumb from "../components/Breadcrumb.astro";
import LibraryLayout from "../layouts/LibraryLayout.astro";
import ReadMarks from "../components/ReadMarks.astro";
import { findResident } from "../data/residents";
import { loadOhako } from "../lib/scripts";

// 暫定導線（Issue #41）: 本編四幕（/story）はまだプレースホルダだが、各住人の「初登場
// （おはこ）」8編は先に読める。ここで main/ohako-*.md 8本への入口を出しておく。
// 四幕を実装したら、この「先に読める8編」節は畳んで本編（四幕）の目次に置き換える前提。
const ohako = loadOhako();
---

<LibraryLayout
  title="物語を辿る ── せおはやみ"
  description="せおはやみ本編（四幕）。近日公開。各住人の初登場は先に読めます。"
  bgImage="shadow-library/history-hall.webp"
>
  <div class="max-w-2xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "叡智の星海", href: "/" }, { label: "物語を辿る" }]} />

    <section class="th-panel p-8 mt-8 text-center">
      <h1 class="text-2xl mb-4" style="color: var(--color-th-theo);">物語を辿る</h1>
      <p class="leading-loose text-sm" style="color: var(--color-th-ivory-dim);">
        本編（四幕）はまだこの書架に並んでいません。近日、ここに置かれます。<br />
        それまでは自由行動として、住人から、または業から問答を選べます。
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-6">
        <a href="/anthology" class="th-link-button no-underline">住人から選ぶ</a>
        <a href="/themes" class="th-link-button no-underline">業から選ぶ</a>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-base mb-2 th-glow" style="color: var(--color-th-gold-bright);">先に読める8編</h2>
      <p class="leading-loose text-sm mb-5 th-glow" style="color: var(--color-th-ivory-dim);">
        本編は準備中ですが、各住人の「初登場」──せおと初めて交わした問答──は先に読めます。
      </p>
      <ul class="th-theme-grid">
        {
          ohako.map((entry) => {
            const resident = findResident(entry.character);
            return (
              <li>
                {/* data-slug は ReaderFrame が完読時に markRead する slug（= entry.slug）と同一。
                    free の扉と同じ規約で ReadMarks が既読なら金の読了印（.th-door.is-read）を付ける。 */}
                <a href={`/main/${entry.slug}`} data-slug={entry.slug} class="th-door block no-underline">
                  <p style="color: var(--color-th-ivory);">{entry.title}</p>
                  {resident && (
                    <p class="text-xs mt-2" style="color: var(--color-th-ivory-dim);">
                      {resident.name}（叡智：{resident.ability}）
                    </p>
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>
  </div>
  <ReadMarks />
</LibraryLayout>

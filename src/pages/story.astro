---
import Breadcrumb from "../components/Breadcrumb.astro";
import LibraryLayout from "../layouts/LibraryLayout.astro";
import ReadMarks from "../components/ReadMarks.astro";
import { findResident } from "../data/residents";
import { groupStoryButtonsByAct, loadStoryButtons } from "../lib/scripts";
import {
  createInitialStoryProgress,
  isStorySectionVisible,
  selectVisibleStoryIds,
} from "../lib/storyProgress";

const storyButtons = loadStoryButtons();
const storyIds = storyButtons.map((entry) => entry.slug);
const storySections = groupStoryButtonsByAct(storyButtons);

// SSR の初期可視集合は「クライアントで進捗を読む前」の状態＝先頭ボタンだけ解放。
// 表示すべき storyId 集合・幕見出しの可視判定はどちらも storyProgress.ts の
// 純粋関数（selectVisibleStoryIds / isStorySectionVisible）に寄せ、client 側の
// applyStoryGate と同じ経路を通す（doctrine 規律3・テストが本番退行を捕まえる）。
const initialUnlockedStoryIds = createInitialStoryProgress(storyIds).unlockedStoryIds;
const initialVisibleStoryIds = new Set(selectVisibleStoryIds(storyIds, initialUnlockedStoryIds));

// 幕見出しの表示文言。分割ロジック自体は scripts.ts の groupStoryButtonsByAct() が正本
// （ここは各幕番号にどの見出し文言を当てるかという表示コピーだけを持つ）。
const ACT_SECTION_HEADINGS: Record<number, string> = {
  1: "第一幕　到着とはじめての問答",
  2: "第二幕　最初の消失",
};
---

<LibraryLayout
  title="物語を辿る ── せおはやみ"
  description="せおはやみ本編。ひとつ読み終えるたびに次の書架が開きます。"
  bgImage="shadow-library/history-hall.webp"
  ogImage="promotional/cast/story-opening.webp"
>
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb trail={[{ label: "トップ", href: "/" }, { label: "物語を辿る" }]} />

    <section class="th-story-opening mt-8">
      <img
        src="/images/promotional/cast/story-opening.webp"
        alt=""
        loading="eager"
      />
      <div class="th-story-opening__copy th-glow">
        <p class="th-magazine-section__folio">002 / STORY</p>
        <h1>物語を辿る</h1>
      </div>
    </section>

    <section class="th-story-index-intro mt-8">
      <p class="th-story-index__intro">
        影の図書館への到着から、物語は始まります。ひとつ読み終えると、次の書架が開きます。住人たちとの初めての問答も、この第一幕の流れの中で辿ります。
      </p>
    </section>

    <section class="mt-10" data-story-index data-story-ids={JSON.stringify(storyIds)}>
      {
        storySections.map((section, sectionIndex) => {
          // 幕見出しセクションは、配下に表示ボタンが1つでもあるときだけ出す。
          // 判定は client 側 applyStoryGate と同じ純粋関数（isStorySectionVisible）。
          const sectionInitiallyVisible = isStorySectionVisible(
            section.buttons.map((entry) => entry.slug),
            initialUnlockedStoryIds,
          );
          return (
            <div class:list={[sectionIndex > 0 && "mt-10"]} data-story-section hidden={!sectionInitiallyVisible}>
              <h2 class="text-base mb-3 th-glow" style="color: var(--color-th-gold-bright);">
                {ACT_SECTION_HEADINGS[section.act] ?? `第${section.act}幕`}
              </h2>
              <ol class="th-story-button-grid">
                {
                  section.buttons.map((entry) => {
                    const resident = entry.character ? findResident(entry.character) : undefined;
                    const initiallyUnlocked = initialVisibleStoryIds.has(entry.slug);
                    return (
                      <li data-story-item={entry.slug} hidden={!initiallyUnlocked}>
                        <a
                          href={initiallyUnlocked ? `/main/${entry.slug}` : undefined}
                          data-href={`/main/${entry.slug}`}
                          data-story-link={entry.slug}
                          data-slug={entry.slug}
                          class="th-door th-story-button block no-underline"
                        >
                          <span class="th-story-button__number">{String(entry.orderInAct).padStart(2, "0")}</span>
                          <p style="color: var(--color-th-ivory);">{entry.title}</p>
                          {resident && (
                            <p class="text-xs mt-2" style="color: var(--color-th-ivory-dim);">
                              {resident.name}（叡智：{resident.ability}）
                            </p>
                          )}
                        </a>
                      </li>
                    );
                  })
                }
              </ol>
            </div>
          );
        })
      }
    </section>
  </div>
  <ReadMarks />
</LibraryLayout>

<script>
  import {
    getStoryProgress,
    isStorySectionVisible,
    selectVisibleStoryIds,
  } from "../lib/storyProgress";

  function applyStoryGate() {
    const root = document.querySelector<HTMLElement>("[data-story-index]");
    if (!root) return;
    const storyIds = JSON.parse(root.dataset.storyIds ?? "[]") as string[];
    const { unlockedStoryIds } = getStoryProgress(storyIds);

    // 表示すべき storyId 集合・可視セクション判定はどちらも純粋関数で計算し、
    // その結果で hidden を付け外しする（SSR と同一経路・テストが本番退行を捕まえる）。
    // 未解放ボタンは非表示（見せない）。表示するのは読了済み＋次の1つだけ。
    const visible = new Set(selectVisibleStoryIds(storyIds, unlockedStoryIds));
    for (const item of root.querySelectorAll<HTMLElement>("[data-story-item]")) {
      const storyId = item.dataset.storyItem ?? "";
      const isVisible = visible.has(storyId);
      item.hidden = !isVisible;
      const link = item.querySelector<HTMLAnchorElement>("[data-story-link]");
      if (link) {
        if (isVisible) {
          link.href = link.dataset.href ?? link.href;
        } else {
          link.removeAttribute("href");
        }
      }
    }

    // 幕見出しセクションは、配下に表示ボタンが1つも無ければ見出しごと非表示。
    for (const section of root.querySelectorAll<HTMLElement>("[data-story-section]")) {
      const sectionStoryIds = [...section.querySelectorAll<HTMLElement>("[data-story-item]")].map(
        (item) => item.dataset.storyItem ?? "",
      );
      section.hidden = !isStorySectionVisible(sectionStoryIds, unlockedStoryIds);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", applyStoryGate);
  } else {
    applyStoryGate();
  }
</script>

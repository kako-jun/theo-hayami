---
import Breadcrumb from "../../components/Breadcrumb.astro";
import ReaderFrame from "../../components/ReaderFrame.astro";
import LibraryLayout from "../../layouts/LibraryLayout.astro";
import { findResident } from "../../data/residents";
import { loadEpisodes } from "../../lib/scripts";

export function getStaticPaths() {
  return loadEpisodes().map((episode) => ({
    params: { slug: episode.slug },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const resident = findResident(episode.character);
if (!resident) {
  throw new Error(`未知の住人スラッグ: ${episode.character}`);
}

// このセルが実際に開く場面の背景（脚本MD先頭の [背景: ...] から取得）を額縁の背景にも使う。
// 見つからない場合は選択画面と同じ既定背景にフォールバックする。
const bgImage = episode.background ?? "shadow-library/grand-reading-room-v.webp";
---

<LibraryLayout
  title={`${episode.themeTitle} ── ${resident.name} ── せおはやみ`}
  description={`「${episode.themeTitle}」を${resident.name}（${resident.thought}）に訊く。`}
  bgImage={bgImage}
  ogImage={`promotional/residents/${resident.slug}-feature.webp`}
>
  <div class="max-w-3xl mx-auto px-4 pt-10 pb-16">
    <Breadcrumb
      trail={[
        { label: "トップ", href: "/" },
        { label: "業から選ぶ", href: "/themes" },
        { label: episode.themeTitle, href: `/themes/${episode.theme}` },
        { label: resident.name },
      ]}
    />

    <header class="text-center my-8 th-glow">
      <h1 class="text-xl sm:text-2xl" style="color: var(--color-th-theo);">「{episode.themeTitle}」</h1>
      <p class="mt-2 text-sm" style="color: var(--color-th-gold-bright);">
        {resident.name}に訊く（{resident.thought}）
      </p>
    </header>

    <ReaderFrame
      slug={episode.slug}
      sceneId={episode.sceneId}
      title={`${episode.themeTitle} ── ${resident.name}`}
      markReadOnStart={episode.keepTerminalEventImage}
    />

    <nav class="th-path-tree th-path-tree--after-reader" aria-label="このあと">
      <div class="th-path-tree__branch" aria-label="住人から選ぶ">
        <div class="th-path-tree__branch-head">
          <p class="th-path-tree__label">住人から選ぶ</p>
        </div>
        <div class="th-path-tree__children">
          <a href={`/residents/${episode.character}`} class="th-path-tree__item">
            <span class="th-path-tree__label">選択中の住人</span>
            <span class="th-path-tree__text">{resident.name}に別の業を訊く</span>
          </a>
          <a href="/anthology" class="th-path-tree__item">
            <span class="th-path-tree__label">住人一覧</span>
            <span class="th-path-tree__text">別の住人を選ぶ</span>
          </a>
        </div>
      </div>
      <div class="th-path-tree__branch" aria-label="業から選ぶ">
        <div class="th-path-tree__branch-head">
          <p class="th-path-tree__label">業から選ぶ</p>
        </div>
        <div class="th-path-tree__children">
          <a href={`/themes/${episode.theme}`} class="th-path-tree__item">
            <span class="th-path-tree__label">選択中の業</span>
            <span class="th-path-tree__text">「{episode.themeTitle}」を別の住人に訊く</span>
          </a>
          <a href="/themes" class="th-path-tree__item">
            <span class="th-path-tree__label">業一覧</span>
            <span class="th-path-tree__text">別の業を選ぶ</span>
          </a>
        </div>
      </div>
    </nav>
  </div>
</LibraryLayout>

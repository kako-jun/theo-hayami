{
  "name": "theo-hayami",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "build-nameplates": "node scripts/build-nameplates.mjs",
    "sync-assets": "node scripts/sync-assets.mjs",
    "place-tachie": "node scripts/place-tachie-on-canvas.mjs",
    "dev": "npm run sync-assets && astro dev --host 127.0.0.1 --port 4321",
    "build": "npm run sync-assets && PUBLIC_BUILD_DATE=$(TZ=Asia/Tokyo date +%Y-%m-%d) astro build && npm run check-sitemap && npm run build:sw",
    "build:sw": "node scripts/build-sw.mjs",
    "check-sitemap": "node scripts/check-sitemap.mjs",
    "preview": "astro preview",
    "typecheck": "astro check",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^7.0.9",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^24.13.3",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.6",
    "workbox-precaching": "^7.4.1"
  }
}
